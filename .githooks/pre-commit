#!/bin/sh

echo "Running cargo clippy before commit..."
if ! cargo clippy --all-targets -- -D warnings; then
	cat >&2 <<EOF

✖ Commit aborted: cargo clippy found problems in the code.

  Fix the reported issues before committing, or bypass with:
    git commit --no-verify

EOF
	exit 1
fi

echo "Running cargo test before commit..."
if ! cargo test; then
	cat >&2 <<EOF

✖ Commit aborted: cargo test failed.

  Fix the failing tests before committing, or bypass with:
    git commit --no-verify

EOF
	exit 1
fi

exit 0
